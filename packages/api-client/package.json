{
  "name": "@open-dpp/api-client",
  "version": "0.4.1",
  "description": "A client for my API",
  "keywords": [],
  "homepage": "https://github.com/open-dpp/open-dpp#readme",
  "bugs": {
    "url": "https://github.com/open-dpp/open-dpp/issues"
  },
  "license": "ISC",
  "author": "open-dpp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-dpp/open-dpp.git",
    "directory": "packages/api-client"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "test": "jest",
    "check-ts": "tsc --noEmit",
    "run-before-versions": "npm run build && npm run test",
    "prepatch": "npm run run-before-versions",
    "patch": "git fetch --tags && npm version patch && git push --follow-tags",
    "preminor": "npm run run-before-versions",
    "minor": "git fetch --tags && npm version minor && git push --follow-tags",
    "premajor": "npm run run-before-versions",
    "major": "git fetch --tags && npm version major && git push --follow-tags",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@open-dpp/dto": "workspace:*",
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@open-dpp/testing": "workspace:*",
    "@rollup/plugin-typescript": "^12.3.0",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "msw": "^2.13.3",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
