{
  "name": "open-dpp",
  "description": "",
  "license": "LGPL-3.0-only",
  "author": "open-dpp GmbH",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "build": "turbo build --env-mode=loose",
    "build:main": "turbo build --filter=./apps/main --env-mode=loose",
    "build:docs": "turbo docs:build --filter=./docs",
    "dev": "dotenvx run -f .env.dev -f .env -- turbo dev --env-mode=loose",
    "test": "dotenvx run -f .env.dev -f .env -- turbo test --env-mode=loose",
    "test:ci": "turbo test --env-mode=loose",
    "test:e2e": "dotenvx run -f .env.dev -f .env -- turbo e2e-test --filter=./apps/e2e --env-mode=loose",
    "test:main": "dotenvx run -f .env.dev -f .env -- turbo test --filter=./apps/main --env-mode=loose",
    "test:aas": "dotenvx run -f .env.dev -f .env -- turbo test --filter=./packages/aas --env-mode=loose",
    "test:auth": "dotenvx run -f .env.dev -f .env -- turbo test --filter=./packages/auth --env-mode=loose",
    "test:client": "dotenvx run -f .env.dev -f .env -- turbo test --filter=./apps/client --env-mode=loose",
    "test:api-client": "dotenvx run -f .env.dev -f .env -- turbo test --filter=./packages/api-client --env-mode=loose",
    "test:debug": "dotenvx run -f .env.dev -f .env -- turbo test:debug --env-mode=loose",
    "test:debug:main": "dotenvx run -f .env.dev -f .env -- turbo test:debug --filter=./apps/main --env-mode=loose",
    "dev:main": "dotenvx run -- turbo dev --filter=./apps/main --env-mode=loose",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@dotenvx/dotenvx": "^1.61.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "turbo": "^2.9.6"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
